<?xml version="1.0" encoding="UTF-8"?>
<FindBugsFilter>
    <!--
      Hibernate-managed JPA entities and Lombok @Getter/@Setter intentionally
      expose mutable references to associated entities (User, Show, etc.) and
      to JPA-managed collections. Suppress EI_EXPOSE_REP[2] for these.
    -->
    <Match>
        <Or>
            <Package name="com.booking.entity"/>
            <Package name="com.booking.dto"/>
        </Or>
        <Or>
            <Bug pattern="EI_EXPOSE_REP"/>
            <Bug pattern="EI_EXPOSE_REP2"/>
        </Or>
    </Match>
</FindBugsFilter>
